// ============================================================================
// synth_top.cst — Physical constraints (pin-toewijzing) Tang Primer 20K Dock
//
// Pinnen geverifieerd tegen het officiële Sipeed PT8211-voorbeeld
// (github.com/sipeed/TangPrimer-20K-example, PT8211/src/pinmap.cst).
// IO_TYPE bewust weggelaten — Gowin kiest de juiste standaard per bank (zoals
// het Sipeed-voorbeeld doet). Klok = 27 MHz op H11; synth_top draait native op
// 27 MHz (SYS_CLK_HZ default). Zie doc/FLASHING.md.
// ============================================================================

// ---- Klok, reset, LED (genoeg voor de eerste flash: LED-heartbeat) --------
IO_LOC  "sys_clk"   H11;          // 27 MHz onboard kristal
IO_PORT "sys_clk"   PULL_MODE=UP;
IO_LOC  "sys_rst_n" T3;           // drukknop (active-low; PULL_MODE=UP = idle hoog)
IO_PORT "sys_rst_n" PULL_MODE=UP;
IO_LOC  "led"       L16;          // één van de 6 LED's
IO_PORT "led"       PULL_MODE=UP;
IO_LOC  "key_mute_n" T4;          // DIP-switch (niveau): stand bepaalt audio aan/uit
IO_PORT "key_mute_n" PULL_MODE=UP;
IO_LOC  "wah_sw"     E8;          // schakelaar (niveau): wah aan/uit (hoog=aan)
IO_PORT "wah_sw"     PULL_MODE=UP;

// ---- Onboard PT8211 stereo-DAC → 3.5mm jack (pt8211_tx is gewired) ----
// DRIVE laag (4) gehouden om digitale koppeling in de analoge sectie te beperken.
IO_LOC  "hp_bck" N15;  IO_PORT "hp_bck" PULL_MODE=UP DRIVE=4;   // bit-clock
IO_LOC  "hp_ws"  P16;  IO_PORT "hp_ws"  PULL_MODE=UP DRIVE=4;   // word-select (L/R)
IO_LOC  "hp_din" P15;  IO_PORT "hp_din" PULL_MODE=UP DRIVE=4;   // data
IO_LOC  "pa_en"  R16;  IO_PORT "pa_en"  PULL_MODE=UP DRIVE=4;   // versterker-enable

// ---- SPI-slave van de brain (Fase 2 hardware — kies vrije PMOD-pinnen) -----
// Vul met PMOD-pinnen uit de Sipeed-pinout zodra je de brain koppelt.
// IO_LOC "spi_sclk" <PIN>;  IO_PORT "spi_sclk" PULL_MODE=UP;
// IO_LOC "spi_mosi" <PIN>;  IO_PORT "spi_mosi" PULL_MODE=UP;
// IO_LOC "spi_miso" <PIN>;  IO_PORT "spi_miso" PULL_MODE=UP DRIVE=8;
// IO_LOC "spi_cs_n" <PIN>;  IO_PORT "spi_cs_n" PULL_MODE=UP;
// IO_LOC "demo_mode" <PIN>; IO_PORT "demo_mode" PULL_MODE=UP;   // bijv. DIP-switch

// audio_out[31:0] is een sim-bus; op hardware vervangt pt8211_tx die.
// spi_*/demo_mode/audio_out mogen tijdens de LED-test onbeperkt (unconstrained)
// blijven — Gowin plaatst ze dan automatisch (onschuldig zolang niets erop zit).
